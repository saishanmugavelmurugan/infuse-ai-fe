# HealthTrack Pro Web Portal Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED
# ===========================================

# Backend API URL
# Development: http://localhost:8001
# Production: https://api.yourdomain.com
REACT_APP_BACKEND_URL=http://localhost:8001

# ===========================================
# OPTIONAL - Feature Flags
# ===========================================

# Enable/disable features
REACT_APP_ENABLE_VIDEO_CONSULTING=true
REACT_APP_ENABLE_AI_WELLNESS=true
REACT_APP_ENABLE_LAB_INTEGRATION=true

# ===========================================
# OPTIONAL - Analytics & Monitoring
# ===========================================

# Google Analytics
REACT_APP_GA_TRACKING_ID=

# Sentry Error Tracking
REACT_APP_SENTRY_DSN=

# ===========================================
# OPTIONAL - Third Party Integrations
# ===========================================

# Google Maps (for doctor location)
REACT_APP_GOOGLE_MAPS_API_KEY=

# ===========================================
# BUILD CONFIGURATION
# ===========================================

# Build version (auto-populated in CI/CD)
REACT_APP_VERSION=$npm_package_version

# Build environment
REACT_APP_ENV=development
